# ==========================================
# YIMSTORE E-COMMERCE ENVIRONMENT VARIABLES
# ==========================================

# 1. Supabase Client Keys
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# 2. Supabase Server Keys (Hanya untuk Backend / API Route)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# 3. Pakasir Payment Gateway Keys
PAKASIR_PROJECT_SLUG="web-tele"
PAKASIR_API_KEY="your-pakasir-api-key"

# 4. Telegram Bot Keys
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your-bot-username"
TELEGRAM_ADMIN_CHAT_ID="your-admin-chat-id"

# 5. Upstash Redis (For Rate Limiting & Webhook Idempotency)
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# 6. Global Site URL
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
